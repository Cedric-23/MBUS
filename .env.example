# production = live public site (hides errors, blocks dbtest.php)
MBUS_ENV=local

# Supabase PostgreSQL (required)
# Use Session pooler host from Dashboard → Settings → Database → Connection string
SUPABASE_DB_HOST=aws-1-ap-south-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.xeczvnheaixpfattbwsk
SUPABASE_DB_PASSWORD=your_database_password_here

# Supabase API (optional — for future clients)
SUPABASE_URL=https://xeczvnheaixpfattbwsk.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
